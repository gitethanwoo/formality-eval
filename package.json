{
  "name": "formality-eval",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "eval": "node --env-file=.env --import tsx/esm src/index.ts",
    "eval:all": "node --env-file=.env --import tsx/esm src/index.ts --all",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && node --import tsx/esm scripts/test-sandbox.ts && node --env-file=.env --import tsx/esm scripts/test-env.ts",
    "generate-seeds": "tsx scripts/generate-seed-files.ts"
  },
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/openai": "^3.0.30",
    "ai": "^6.0.95",
    "bash-tool": "^1.3.15",
    "just-bash": "^2.10.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
